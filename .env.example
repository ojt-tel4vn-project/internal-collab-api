# ─────────────────────────────────────────────────────────────
# Internal Collab API — Environment Variables
#
# SETUP INSTRUCTIONS:
#   cp .env.example .env
#   Then fill in all required values marked with <...>
#
# ⚠️  Never commit .env to git — it contains secrets!
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
# URL of the frontend app — used to build links in emails (e.g. password reset)
FRONTEND_URL=http://localhost:3000

# ── Database (Supabase Pooler) ────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection Pooling
DB_HOST=<your-project-ref>.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=<your-database-password>
DB_NAME=postgres
DB_SSLMODE=require

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters, use a random string in production
JWT_SECRET=<your-super-secret-jwt-key-min-32-chars>
JWT_EXPIRATION_HOURS=24

# ── Email — Brevo (SendinBlue) ────────────────────────────────
# Get API key from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=<your-brevo-api-key>
EMAIL_FROM=<your-sender-email@domain.com>
EMAIL_FROM_NAME=Internal Collaboration System

# ── Supabase Storage ──────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
# Create a bucket named "documents" in: Storage → New Bucket
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_BUCKET=documents
SUPABASE_API_KEY=<your-supabase-service-role-key>
